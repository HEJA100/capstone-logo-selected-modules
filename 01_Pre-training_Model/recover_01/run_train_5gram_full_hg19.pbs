#!/bin/bash
#PBS -N logo01_tr5g_full_hg19
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb
#PBS -l walltime=120:00:00
#PBS -j oe
#PBS -o /home/users/nus/e1538285/scratch/LOGO/01_Pre-training_Model/recover_01/logs/logo01_tr5g_full_hg19.$PBS_JOBID.log

set -euo pipefail

cd /home/users/nus/e1538285/scratch/LOGO/01_Pre-training_Model

source ~/miniconda3/etc/profile.d/conda.sh
conda activate logo

echo "START: $(date)"
hostname
nvidia-smi || true

mkdir -p /home/users/nus/e1538285/scratch/LOGO/data/pretrain_full_runs/5gram_hg19

/usr/bin/time -v python 02_train_gene_transformer_lm_hg_bert4keras_tfrecord.py \
  --save /home/users/nus/e1538285/scratch/LOGO/data/pretrain_full_runs/5gram_hg19 \
  --train-data /home/users/nus/e1538285/scratch/LOGO/data/hg19/train_5_gram_tfrecord \
  --seq-len 1000 \
  --model-dim 256 \
  --transformer-depth 2 \
  --num-heads 8 \
  --batch-size 256 \
  --ngram 5 \
  --stride 5 \
  --model-name genebert_5_gram_full_hg19 \
  --steps-per-epoch 4000 \
  --epochs 50 \
  --shuffle-size 4000 \
  --num-gpu 1 \
  --verbose 1

echo "END: $(date)"

#!/bin/bash
#PBS -N logo919_test_ft11
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb
#PBS -l walltime=04:00:00
#PBS -j oe
#PBS -o /home/users/nus/e1538285/scratch/LOGO/04_LOGO_Chromatin_Feature/my_repro_04_rerun919/optimize_best113_lr1e5/logs/logo919_test_ft11.log

set -euo pipefail

source ~/miniconda3/etc/profile.d/conda.sh
conda activate logo

cd /home/users/nus/e1538285/scratch/LOGO
export PYTHONPATH=/home/users/nus/e1538285/scratch/LOGO:${PYTHONPATH:-}

echo "START: $(date)"
hostname
nvidia-smi || true
python -V

WEIGHT="/home/users/nus/e1538285/scratch/LOGO/04_LOGO_Chromatin_Feature/my_repro_04_rerun919/optimize_best113_lr1e5/weights/deepsea_5_gram_2_layer_8_heads_256_dim_990_ft_best113_lr1e5_weights_11-0.979833-0.982337.hdf5"
echo "WEIGHT=$WEIGHT"

mkdir -p /home/users/nus/e1538285/scratch/LOGO/04_LOGO_Chromatin_Feature/my_repro_04_rerun919/optimize_best113_lr1e5/metrics

CUDA_VISIBLE_DEVICES=0 python "/home/users/nus/e1538285/scratch/LOGO/04_LOGO_Chromatin_Feature/1. script/04_LOGO_Chrom_919/02_deep_sea_train_classification_tfrecord.py" \
  --save "/home/users/nus/e1538285/scratch/LOGO/04_LOGO_Chromatin_Feature/my_repro_04_rerun919/optimize_best113_lr1e5/metrics" \
  --weight-path "$WEIGHT" \
  --test-data "/home/users/nus/e1538285/scratch/LOGO/04_LOGO_Chromatin_Feature/1. script/04_LOGO_Chrom_919/data/deepsea/DeepSEA_data/test_5_gram" \
  --we-size 128 \
  --model-dim 256 \
  --transformer-depth 1 \
  --num-heads 8 \
  --batch-size 512 \
  --ngram 5 \
  --stride 1 \
  --num-classes 919 \
  --model-name deepsea_5_gram_2_layer_8_heads_256_dim_990_ft_best113_lr1e5 \
  --use-conv \
  --use-position \
  --class-prediction \
  --verbose 1 \
  --task test

echo "END: $(date)"
